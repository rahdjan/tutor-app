// Схема данных платформы для репетиторов.
// User/Session/Account/Verification — таблицы, которые требует Better Auth (авторизация).
// Invite — одноразовые приглашения учеников.
// Student/Topic/Task/Worksheet/StudyPlan/Assignment/Submission — учебное ядро (Фаза 3).
// Lesson/Payment — заготовки под расписание и оплаты (Фазы 9–10).
// Подключение к БД настраивается через DATABASE_URL в .env (см. prisma.config.ts).
//
// Правило изоляции: у всего контента репетитора есть tutorId, и каждый запрос
// в коде обязан фильтроваться по нему (см. lib/access.ts).

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  // Явные расширения в импортах — чтобы сид работал в чистом Node (ESM)
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TUTOR
  STUDENT
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Роль и мультиарендность: у ученика заполнен tutorId — пригласивший репетитор.
  role    Role    @default(TUTOR)
  tutorId String?
  tutor   User?   @relation("TutorStudents", fields: [tutorId], references: [id], onDelete: SetNull)
  students User[] @relation("TutorStudents")

  // Согласия на обработку персональных данных (см. /privacy).
  consentAccepted       Boolean @default(false)
  under16               Boolean @default(false)
  parentConsentAccepted Boolean @default(false)

  sessions Session[]
  accounts Account[]
  invites  Invite[]  @relation("TutorInvites")

  // Контент и записи репетитора
  studentCards Student[]  @relation("TutorStudentCards")
  customTopics Topic[]    @relation("TutorTopics")
  tasks        Task[]
  worksheets   Worksheet[]
  assignments  Assignment[]
  lessons      Lesson[]
  payments     Payment[]

  // Карточка ученика, к которой привязан этот аккаунт (если роль STUDENT)
  studentProfile Student? @relation("StudentAccount")

  @@index([tutorId])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// Одноразовое приглашение ученика: репетитор создаёт ссылку с кодом,
// ученик регистрируется по ней и привязывается к этому репетитору.
model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  label     String? // для репетитора: кому отправил (например, «Маша, 9 класс»)
  expiresAt DateTime
  usedAt    DateTime?
  usedById  String?
  createdAt DateTime  @default(now())

  tutorId String
  tutor   User   @relation("TutorInvites", fields: [tutorId], references: [id], onDelete: Cascade)

  // Карточка ученика, к которой привязано приглашение: после регистрации
  // аккаунт нового пользователя присоединяется именно к этой карточке.
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tutorId])
  @@map("invite")
}

// ==================== Учебное ядро (Фаза 3) ====================

// Цель подготовки ученика
enum Goal {
  EGE_PROF
  EGE_BASE
  OGE
  OTHER
}

// Экзамен, к которому относится тема кодификатора
enum Exam {
  EGE_PROF
  EGE_BASE
  OGE
}

// Тип ответа задачи: SHORT — число/строка с автопроверкой,
// DETAILED — развёрнутое решение, проверяет репетитор.
enum AnswerType {
  SHORT
  DETAILED
}

// Статус освоения темы в программе ученика
enum PlanStatus {
  NOT_STARTED
  IN_PROGRESS
  MASTERED
}

// Карточка ученика — запись репетитора (минимум персональных данных).
// Не то же самое, что аккаунт User: карточку репетитор может завести до того,
// как ученик зарегистрируется; аккаунт привязывается через userId.
model Student {
  id        String    @id @default(cuid())
  name      String // имя или метка, как удобно репетитору
  grade     Int? // класс, например 9 или 11
  goal      Goal      @default(OTHER)
  examDate  DateTime? // дата экзамена, если известна
  notes     String? // заметки репетитора
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tutorId String
  tutor   User   @relation("TutorStudentCards", fields: [tutorId], references: [id], onDelete: Cascade)

  // Аккаунт ученика (появляется после регистрации по приглашению)
  userId String? @unique
  user   User?   @relation("StudentAccount", fields: [userId], references: [id], onDelete: SetNull)

  studyPlans  StudyPlan[]
  assignments Assignment[]
  lessons     Lesson[]
  payments    Payment[]
  invites     Invite[]

  @@index([tutorId])
  @@map("student")
}

// Тема кодификатора ФИПИ или произвольная тема.
// tutorId = null — общий кодификатор (сид), виден всем репетиторам.
// tutorId заполнен — личная тема репетитора, видна только ему.
model Topic {
  id        String  @id @default(cuid())
  title     String
  exam      Exam? // null — произвольная тема вне ЕГЭ/ОГЭ
  section   String? // раздел, например «Часть 1 (краткий ответ)»
  kimNumber Int? // номер задания в КИМ
  fipiCode  String? // код по кодификатору ФИПИ, например «3.1»
  order     Int? // порядок показа внутри экзамена

  tutorId String?
  tutor   User?   @relation("TutorTopics", fields: [tutorId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Topic?  @relation("TopicTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Topic[] @relation("TopicTree")

  tasks     Task[]
  planItems PlanItem[]

  @@index([exam, kimNumber])
  @@index([tutorId])
  @@map("topic")
}

// Задача из банка репетитора. Условие и решение — Markdown с LaTeX (рендер KaTeX).
model Task {
  id         String     @id @default(cuid())
  statement  String // условие
  answerType AnswerType @default(SHORT)
  answer     String? // эталонный ответ для SHORT (автопроверка)
  solution   String? // разбор/решение
  difficulty Int        @default(3) // 1–5
  source     String? // откуда задача
  tags       String[]   @default([])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  tutorId String
  tutor   User   @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  worksheetTasks WorksheetTask[]
  answerEntries  AnswerEntry[]

  @@index([tutorId])
  @@index([topicId])
  @@map("task")
}

// Рабочий лист / тест: подборка задач. Не обязательно ЕГЭ/ОГЭ —
// теги позволяют помечать «7 класс», «Мерзляк» и т.п.
model Worksheet {
  id          String   @id @default(cuid())
  title       String
  description String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tutorId String
  tutor   User   @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  tasks       WorksheetTask[]
  assignments Assignment[]

  @@index([tutorId])
  @@map("worksheet")
}

// Задача внутри рабочего листа (с порядком)
model WorksheetTask {
  id    String @id @default(cuid())
  order Int

  worksheetId String
  worksheet   Worksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([worksheetId, taskId])
  @@index([worksheetId])
  @@map("worksheet_task")
}

// Программа подготовки ученика: выбранные темы с порядком и статусами
model StudyPlan {
  id        String   @id @default(cuid())
  title     String   @default("Программа подготовки")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  items PlanItem[]

  @@index([studentId])
  @@map("study_plan")
}

// Тема внутри программы: статус освоения и плановая дата
model PlanItem {
  id         String     @id @default(cuid())
  order      Int
  status     PlanStatus @default(NOT_STARTED)
  plannedFor DateTime?

  planId String
  plan   StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([planId, topicId])
  @@index([planId])
  @@map("plan_item")
}

// Выдача рабочего листа ученику
model Assignment {
  id         String    @id @default(cuid())
  assignedAt DateTime  @default(now())
  dueAt      DateTime? // срок сдачи

  worksheetId String
  worksheet   Worksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Дублируем tutorId для простой и надёжной изоляции запросов
  tutorId String
  tutor   User   @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  submissions Submission[]

  @@index([tutorId])
  @@index([studentId])
  @@map("assignment")
}

// Прохождение задания учеником
model Submission {
  id          String    @id @default(cuid())
  startedAt   DateTime  @default(now())
  submittedAt DateTime? // null — ещё в работе

  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  entries AnswerEntry[]

  @@index([assignmentId])
  @@map("submission")
}

// Ответ ученика на одну задачу
model AnswerEntry {
  id          String   @id @default(cuid())
  answerText  String? // ответ SHORT или текст решения DETAILED
  fileUrl     String? // фото рукописного решения (облачное хранилище, Фаза 8)
  autoScore   Int? // автобалл за SHORT (0/1)
  manualScore Int? // балл репетитора за DETAILED
  comment     String? // комментарий репетитора
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([submissionId, taskId])
  @@index([submissionId])
  @@map("answer_entry")
}

// ==================== Заготовки под Фазы 9–10 ====================

// Урок (расписание появится в Фазе 10)
model Lesson {
  id          String   @id @default(cuid())
  scheduledAt DateTime
  durationMin Int      @default(60)
  note        String? // тема/конспект
  createdAt   DateTime @default(now())

  tutorId String
  tutor   User   @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tutorId])
  @@index([studentId])
  @@map("lesson")
}

// Оплата (пакеты и баланс появятся в Фазе 10)
model Payment {
  id           String   @id @default(cuid())
  amount       Decimal  @db.Decimal(10, 2)
  paidAt       DateTime @default(now())
  lessonsCount Int? // сколько уроков покрывает (пакет)
  note         String?

  tutorId String
  tutor   User   @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tutorId])
  @@index([studentId])
  @@map("payment")
}

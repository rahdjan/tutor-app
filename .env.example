# Скопируйте этот файл в .env и заполните реальными значениями.
# Строка подключения к PostgreSQL из Neon (Dashboard → Connect → Connection string).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Секрет для подписи сессий Better Auth. Сгенерировать: openssl rand -base64 32
BETTER_AUTH_SECRET="случайная-строка-минимум-32-символа"
# Базовый адрес приложения: локально http://localhost:3000, в проде — адрес сайта.
BETTER_AUTH_URL="http://localhost:3000"

# ИИ-импорт задач: ключ OpenAI-совместимого AI-сервиса (у нас — aitunnel.ru).
AI_API_KEY="sk-aitunnel-..."
# Необязательно: адрес API и модель (по умолчанию aitunnel + gemini-2.5-flash).
# AI_BASE_URL="https://api.aitunnel.ru/v1"
# AI_MODEL="gemini-2.5-flash"
